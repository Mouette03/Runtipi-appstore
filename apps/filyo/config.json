{
  "$schema": "../app-info-schema.json",
  "name": "Filyo",
  "id": "filyo",
  "port": 3587,
  "available": true,
  "exposable": true,
  "dynamic_config": true,
  "tipi_version": 1,
  "version": "v1.0.8",
  "categories": ["utilities"],
  "description": "Self-hosted file sharing with reverse upload requests & password-protected expiry links",
  "short_desc": "Self-hosted file manager",
  "author": "Mouette03",
  "source": "https://github.com/mouette03/filyo",
  "website": "https://github.com/mouette03/filyo",
  "form_fields": [
    {
      "type": "random",
      "label": "JWT Secret",
      "min": 32,
      "max" : 32,
      "env_variable": "FILYO_JWT_SECRET"
    },
    {
      "type": "text",
      "label": "Log Level",
      "required": false,
      "default": "warn",
      "options": [
        {"label": "silent", "value": "silent"},
        {"label": "fatal", "value": "fatal"},
        {"label": "warn", "value": "warn"},
        {"label": "info", "value": "info"},
        {"label": "debug", "value": "debug"}
      ],
      "hint": "Log level for the application.",
      "env_variable": "FILYO_LOG_LEVEL"
    }
  ],
  "supported_architectures": ["arm64", "amd64"],
  "created_at": 1775256417005,
  "updated_at": 1775256417005,
  "min_tipi_version": "4.5.0"
}
